{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "send-email-code missing email returns 400",
      "method": "POST",
      "path": "/?action=send-email-code",
      "body": { "email": "" },
      "expectedStatus": 400
    },
    {
      "name": "verify-email-code missing fields returns 400",
      "method": "POST",
      "path": "/?action=verify-email-code",
      "body": { "login": "", "code": "" },
      "expectedStatus": 400
    },
    {
      "name": "send-sms-code missing login returns 400",
      "method": "POST",
      "path": "/?action=send-sms-code",
      "body": { "login": "", "password": "" },
      "expectedStatus": 400
    },
    {
      "name": "send-sms-code wrong creds returns 401",
      "method": "POST",
      "path": "/?action=send-sms-code",
      "body": { "login": "nobody_xyz", "password": "wrong", "iis_code": "ABC12" },
      "expectedStatus": 401
    },
    {
      "name": "verify-sms-code missing fields returns 400",
      "method": "POST",
      "path": "/?action=verify-sms-code",
      "body": { "login": "", "code": "" },
      "expectedStatus": 400
    },
    {
      "name": "verify-iis empty returns 400",
      "method": "POST",
      "path": "/?action=verify-iis",
      "body": { "iis_code": "" },
      "expectedStatus": 400
    },
    {
      "name": "verify-iis unknown returns 403",
      "method": "POST",
      "path": "/?action=verify-iis",
      "body": { "iis_code": "ZZ999" },
      "expectedStatus": 403
    },
    {
      "name": "uds-login missing fields returns 400",
      "method": "POST",
      "path": "/?action=uds-login",
      "body": { "login": "" },
      "expectedStatus": 400
    },
    {
      "name": "me without auth returns 401",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401
    },
    {
      "name": "employees without access returns 403",
      "method": "GET",
      "path": "/?action=employees",
      "expectedStatus": 403
    },
    {
      "name": "unknown action returns 403 (no access)",
      "method": "GET",
      "path": "/?action=nope",
      "expectedStatus": 403
    },
    {
      "name": "mail-status without auth returns 403",
      "method": "GET",
      "path": "/?action=mail-status",
      "expectedStatus": 403
    },
    {
      "name": "mail-send without auth returns 403",
      "method": "POST",
      "path": "/?action=mail-send",
      "body": { "to": "x@ooo29.ru", "body": "hi" },
      "expectedStatus": 403
    },
    {
      "name": "set-mail-password without auth returns 403",
      "method": "POST",
      "path": "/?action=set-mail-password",
      "body": { "password": "12345678" },
      "expectedStatus": 403
    },
    {
      "name": "set-subrole without auth returns 403",
      "method": "POST",
      "path": "/?action=set-subrole",
      "body": { "target_login": "x", "subrole": "curator" },
      "expectedStatus": 403
    },
    {
      "name": "set-curator without auth returns 403",
      "method": "POST",
      "path": "/?action=set-curator",
      "body": { "target_login": "x", "curator_login": "y" },
      "expectedStatus": 403
    },
    {
      "name": "transfers without auth returns 403",
      "method": "GET",
      "path": "/?action=transfers",
      "expectedStatus": 403
    },
    {
      "name": "transfer-respond without auth returns 403",
      "method": "POST",
      "path": "/?action=transfer-respond",
      "body": { "transfer_id": 1, "accept": true },
      "expectedStatus": 403
    },
    {
      "name": "create-my-mailbox without auth returns 403",
      "method": "POST",
      "path": "/?action=create-my-mailbox",
      "body": {},
      "expectedStatus": 403
    }
  ]
}