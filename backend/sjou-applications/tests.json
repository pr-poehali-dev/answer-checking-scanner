{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Submit without required fields returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "submit", "oo_full_name": ""},
      "expectedStatus": 400
    },
    {
      "name": "List without operator password returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "list"},
      "expectedStatus": 401
    },
    {
      "name": "Review without operator password returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "review", "id": 1, "decision": "approved"},
      "expectedStatus": 401
    },
    {
      "name": "Messages without operator password returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "messages", "id": 1},
      "expectedStatus": 401
    },
    {
      "name": "Send message without operator password returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "send_message", "id": 1, "message": "hi"},
      "expectedStatus": 401
    },
    {
      "name": "Unknown action returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "nope"},
      "expectedStatus": 400
    }
  ]
}