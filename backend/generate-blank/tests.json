{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Generate single blank A/B/C/D 20 questions",
      "method": "POST",
      "path": "/",
      "body": { "workId": "123456", "workTitle": "Контрольная по математике", "perPage": 1, "questionsCount": 20, "optionsCount": 4 },
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Generate 2 per page",
      "method": "POST",
      "path": "/",
      "body": { "workId": "654321", "workTitle": "Проверочная", "perPage": 2, "questionsCount": 15, "optionsCount": 4 },
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Generate personalized blanks with students (QR)",
      "method": "POST",
      "path": "/",
      "body": { "workId": "777777", "workTitle": "Тест", "perPage": 2, "questionsCount": 10, "optionsCount": 4, "students": [{ "code": "12345", "name": "Иванов Иван", "classLabel": "9А" }, { "code": "54321", "name": "Петров Пётр", "classLabel": "9А" }] },
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong method returns 405",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405
    }
  ]
}