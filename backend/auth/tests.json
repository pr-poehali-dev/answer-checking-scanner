{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Wrong password returns 401",
      "method": "POST",
      "path": "/",
      "body": { "login": "admin", "password": "wrongpass" },
      "expectedStatus": 401
    },
    {
      "name": "Empty credentials returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Activate trial without login returns 400",
      "method": "POST",
      "path": "/?action=activate-trial",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Check AI limit without login returns 400",
      "method": "POST",
      "path": "/?action=check-ai-limit",
      "body": {},
      "expectedStatus": 400
    }
  ]
}