{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Generate single blank",
      "method": "POST",
      "path": "/",
      "body": { "workId": "123456", "workTitle": "Контрольная по математике", "perPage": 1, "questionsCount": 40 },
      "expectedStatus": 200,
      "expectedBody": { "filename": "string", "pdf": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Generate 2 per page",
      "method": "POST",
      "path": "/",
      "body": { "workId": "654321", "workTitle": "Проверочная", "perPage": 2 },
      "expectedStatus": 200,
      "expectedBody": { "pdf": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Generate 4 per page",
      "method": "POST",
      "path": "/",
      "body": { "workId": "111111", "workTitle": "Test", "perPage": 4 },
      "expectedStatus": 200,
      "expectedBody": { "pdf": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong method returns 405",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405
    }
  ]
}
