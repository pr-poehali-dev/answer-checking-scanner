{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing image returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Invalid base64 returns 400",
      "method": "POST",
      "path": "/",
      "body": { "image": "not-a-base64-!!!" },
      "expectedStatus": 400
    },
    {
      "name": "Tiny image without anchors returns 422",
      "method": "POST",
      "path": "/",
      "body": {
        "image": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="
      },
      "expectedStatus": 422
    },
    {
      "name": "Wrong method returns 405",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405
    }
  ]
}
