{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET not allowed",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405
    },
    {
      "name": "unknown work_type returns 400",
      "method": "POST",
      "path": "/",
      "body": {"work_type": "unknown", "topic": "Тест"},
      "expectedStatus": 400
    },
    {
      "name": "missing topic returns 400",
      "method": "POST",
      "path": "/",
      "body": {"work_type": "essay", "topic": ""},
      "expectedStatus": 400
    },
    {
      "name": "my-works without login returns 400",
      "method": "GET",
      "path": "/?action=my-works",
      "expectedStatus": 400
    },
    {
      "name": "my-works with login returns 200",
      "method": "GET",
      "path": "/?action=my-works&login=testuser",
      "expectedStatus": 200
    }
  ]
}