{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Wrong password returns 401",
      "method": "POST",
      "path": "/",
      "body": { "login": "admin", "password": "wrongpass" },
      "expectedStatus": 401
    },
    {
      "name": "Empty credentials returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Activate trial without login returns 400",
      "method": "POST",
      "path": "/?action=activate-trial",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Check AI limit without login returns 400",
      "method": "POST",
      "path": "/?action=check-ai-limit",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "GET maintenance returns 200",
      "method": "GET",
      "path": "/?action=maintenance",
      "expectedStatus": 200
    },
    {
      "name": "POST maintenance without admin token returns 403",
      "method": "POST",
      "path": "/?action=maintenance",
      "body": { "sections": ["upload"] },
      "expectedStatus": 403
    },
    {
      "name": "Set-role without admin token returns 403",
      "method": "POST",
      "path": "/?action=set-role",
      "body": { "login": "test", "role": "tester" },
      "expectedStatus": 403
    },
    {
      "name": "collective-by-token without params returns 400",
      "method": "GET",
      "path": "/?action=collective-by-token",
      "expectedStatus": 400
    },
    {
      "name": "spend-tokens without login returns 400",
      "method": "POST",
      "path": "/?action=spend-tokens",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "get-tokens-balance without login returns 400",
      "method": "GET",
      "path": "/?action=get-tokens-balance",
      "expectedStatus": 400
    }
  ]
}